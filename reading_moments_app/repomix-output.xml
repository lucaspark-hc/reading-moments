  Widget _buildExplainHelperText() {
    if (_selectedIndexes.isEmpty) {
      return Text(
        '문장을 하나 선택하면 쉽게 풀어보기를 사용할 수 있습니다.',
        style: TextStyle(
          fontSize: 13,
          color: Colors.grey.shade700,
        ),
      );
    }

    if (_hasMultipleSelection) {
      return const Text(
        '문장을 하나만 선택해 주세요.',
        style: TextStyle(
          fontSize: 13,
          color: Colors.orange,
          fontWeight: FontWeight.w600,
        ),
